# ──────────────────────────────────────────────────────────────────────────────
# Shared deployment variables for the 4-VM split.
#
# Copy this file to `.env` INSIDE the deploy folder you are running on each VM,
# e.g.  cp deploy/.env.example deploy/vm2-server/.env
# docker compose automatically reads the `.env` next to the compose file.
#
# Only the variables relevant to a given VM need to be filled in on that VM,
# but it is fine to keep the whole file identical on every VM.
# ──────────────────────────────────────────────────────────────────────────────

# ─── Private-network IPs (the internal interface of each VM) ──────────────────
# These are how the VMs reach each other. Use the private/LAN addresses, NOT the
# public ones. Kafka/Redis/Mongo must never be reachable from the public internet.
VM2_PRIVATE_IP=10.0.0.2      # server + Kafka + Zookeeper + Redis + Mongo
VM3_PRIVATE_IP=10.0.0.3      # serpapiservice (+ its own Mongo)
VM4_PRIVATE_IP=10.0.0.4      # whatsapp-service

# ─── Public URLs (what the browser and Google talk to) ───────────────────────
# Use https:// — the app sends cross-site cookies (withCredentials), which
# browsers only send over HTTPS with SameSite=None.
SERVER_PUBLIC_URL=https://server.mail-or-a.dev   # VM2 public API base
CLIENT_PUBLIC_URL=https://mail-or-a.dev          # VM1 public site

# ─── Public domains for VM3 / VM4 (served via Caddy + auto TLS) ───────────────
# Point these A records at each VM's PUBLIC IP before first boot (ACME needs it).
SEARAPI_DOMAIN=searapi.mail-or-a.dev             # VM3 serpapi public domain
WHATSAPP_DOMAIN=whatsapp.mail-or-a.dev           # VM4 whatsapp public domain
CADDY_EMAIL=admin@mail-or-a.dev                  # Let's Encrypt account email

# ─── Shared API keys protecting the sensitive public endpoints ───────────────
# Long random strings. The SAME value must be set on VM2 (sender) and the
# owning VM (checker). Generate e.g. with:  openssl rand -hex 32
# - WHATSAPP_API_KEY guards VM4  /api/send + /api/send-bulk
# - JOBS_API_KEY     guards VM3  POST /api/jobs/refresh
WHATSAPP_API_KEY=change-me-whatsapp-shared-secret
JOBS_API_KEY=change-me-jobs-shared-secret
