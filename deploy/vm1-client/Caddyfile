# Caddy config for VM1 (client) — SELF-SIGNED TLS for IP-based access.
#
# Accessed via https://<VM1-IP> (no domain), so we listen on the bare ports
# instead of a hostname. Caddy serves HTTPS on :443 using YOUR self-signed
# cert/key (mounted at /certs) and redirects plain HTTP to HTTPS.
# Browsers show a "not trusted" warning (self-signed) — expected.

:80 {
	redir https://{host}{uri} permanent
}

:443 {
	tls /certs/cert.pem /certs/key.pem
	reverse_proxy client:80
}
